{
  "info": {
    "_postman_id": "fit4110-notification-contract-tests",
    "name": "FIT4110 Lab 05 - Notification Compose Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('GET /health -> 200', function () { pm.response.to.have.status(200); });",
              "pm.test('service is notification', function () { const body = pm.response.json(); pm.expect(body.service).to.eql('notification'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Create notification happy path",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}",
            "type": "text"
          },
          {
            "key": "X-Trace-Id",
            "value": "trace-lab-notify-001",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/notifications",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "notifications"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"alert_id\": \"ALERT-20260617-0001\",\n  \"target\": {\n    \"kind\": \"user\",\n    \"user_id\": \"staff-security-01\"\n  },\n  \"channels\": [\n    \"push\",\n    \"sms\",\n    \"email\"\n  ],\n  \"priority\": \"critical\",\n  \"title\": \"Motion detected after hours\",\n  \"message\": \"Camera CAM-A01 detected motion in Library Zone B.\",\n  \"dedupe_key\": \"motion:CAM-A01:20260617T210000\",\n  \"template_code\": \"security_motion_v1\",\n  \"metadata\": {\n    \"building\": \"Library\",\n    \"camera_id\": \"CAM-A01\",\n    \"policy_id\": \"POLICY-AFTER-HOURS\"\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('accepted or duplicate', function () { pm.expect([200, 202]).to.include(pm.response.code); });",
              "const body = pm.response.json();",
              "pm.test('has notification_id', function () { pm.expect(body.notification_id).to.be.a('string'); });",
              "if (body.notification_id) { pm.environment.set('notificationId', body.notification_id); }"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Create duplicate notification",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}",
            "type": "text"
          },
          {
            "key": "X-Trace-Id",
            "value": "trace-lab-notify-001",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/notifications",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "notifications"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"alert_id\": \"ALERT-20260617-0001\",\n  \"target\": {\n    \"kind\": \"user\",\n    \"user_id\": \"staff-security-01\"\n  },\n  \"channels\": [\n    \"push\",\n    \"sms\",\n    \"email\"\n  ],\n  \"priority\": \"critical\",\n  \"title\": \"Motion detected after hours\",\n  \"message\": \"Camera CAM-A01 detected motion in Library Zone B.\",\n  \"dedupe_key\": \"motion:CAM-A01:20260617T210000\",\n  \"template_code\": \"security_motion_v1\",\n  \"metadata\": {\n    \"building\": \"Library\",\n    \"camera_id\": \"CAM-A01\",\n    \"policy_id\": \"POLICY-AFTER-HOURS\"\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('duplicate accepted safely', function () { pm.expect([200, 202]).to.include(pm.response.code); });",
              "const body = pm.response.json();",
              "pm.test('dedupe_key is returned', function () { pm.expect(body.dedupe_key).to.eql('motion:CAM-A01:20260617T210000'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - List notifications",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/notifications?limit=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "notifications"
          ],
          "query": [
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('list -> 200', function () { pm.response.to.have.status(200); });",
              "pm.test('items array exists', function () { pm.expect(pm.response.json().items).to.be.an('array'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - Get notification detail",
      "request": {
        "method": "GET",
        "header": [
          {
