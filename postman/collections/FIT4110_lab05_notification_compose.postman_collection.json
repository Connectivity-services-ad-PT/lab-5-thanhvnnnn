          ],
          "path": [
            "notifications",
            "{{notificationId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('detail -> 200', function () { pm.response.to.have.status(200); });",
              "pm.test('attempts array exists', function () { pm.expect(pm.response.json().attempts).to.be.an('array'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - Retry notification",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/notifications/{{notificationId}}/retry",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "notifications",
            "{{notificationId}}",
            "retry"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('retry accepted or conflict', function () { pm.expect([202, 409]).to.include(pm.response.code); });"
            ]
          }
        }
      ]
    },
