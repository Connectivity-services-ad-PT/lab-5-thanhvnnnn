            ]
          }
        }
      ]
    },
    {
      "name": "08 - Missing auth should be rejected",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/notifications",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "notifications"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"alert_id\": \"ALERT-20260617-0001\",\n  \"target\": {\n    \"kind\": \"user\",\n    \"user_id\": \"staff-security-01\"\n  },\n  \"channels\": [\n    \"push\",\n    \"sms\",\n    \"email\"\n  ],\n  \"priority\": \"critical\",\n  \"title\": \"Motion detected after hours\",\n  \"message\": \"Camera CAM-A01 detected motion in Library Zone B.\",\n  \"dedupe_key\": \"motion:CAM-A01:20260617T210000\",\n  \"template_code\": \"security_motion_v1\",\n  \"metadata\": {\n    \"building\": \"Library\",\n    \"camera_id\": \"CAM-A01\",\n    \"policy_id\": \"POLICY-AFTER-HOURS\"\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('missing auth -> 401', function () { pm.response.to.have.status(401); });",
              "pm.test('problem details body', function () { const body = pm.response.json(); pm.expect(body.status).to.eql(401); });"
            ]
          }
        }
      ]
    },
    {
      "name": "09 - Invalid payload should fail validation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/notifications",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "notifications"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"alert_id\": \"ALERT-20260617-0002\",\n  \"target\": {\n    \"kind\": \"user\",\n    \"user_id\": \"staff-security-01\"\n  },\n  \"channels\": [],\n  \"priority\": \"urgent\",\n  \"title\": \"Bad payload\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('invalid payload -> 422', function () { pm.response.to.have.status(422); });",
              "pm.test('problem details body', function () { const body = pm.response.json(); pm.expect(body.status).to.eql(422); });"
            ]
          }
        }
      ]
    },
